<div class="bit-array">
	<aside>@(BitOffset)</aside>
	@for (int i = 7; i >= 0; i--)
	{
		int offset = i;
		<button @onclick="@(() => ToggleBit(offset))">@((CurrentByte >> offset) & 1)</button>
		if (offset == 4)
		{
			<div />
		}
	}
</div>

@code {
	[Parameter] public int BitOffset { get; set; }
	[Parameter] public byte CurrentByte { get; set; }
	[Parameter] public EventCallback<ChangeEventArgs> OnModify { get; set; }

	private void ToggleBit(int offset)
	{
		byte newByte = (byte)(CurrentByte ^ (1 << offset));
		ByteModifier byteModifier = new ByteModifier(newByte, BitOffset);

		ChangeEventArgs args = new();
		args.Value = byteModifier;
		OnModify.InvokeAsync(args);
	}
}
