<div class="@(Name)">
	<button @onclick="@(Copy)"><img src="./copy.svg" /></button>
	<button class="@(SelectedString)" @onclick="@(UpdateDisplayMode)"><b>@(Prefix):&nbsp;</b>@(Text)</button>
</div>

@code {
	[Parameter] public string Prefix { get; set; } = "";
	[Parameter] public string Text { get; set; } = "";
	[Parameter] public bool Selected { get; set; }
	[Parameter] public EventCallback Copy { get; set; }
	[Parameter] public EventCallback UpdateDisplayMode { get; set; }

	public string Name => "value-reader " + SelectedString;
	public string SelectedString =>  Selected ? "selected" : "";
}
